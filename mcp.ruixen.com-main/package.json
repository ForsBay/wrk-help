{
  "name": "@ruixen/mcp",
  "version": "1.0.1",
  "description": "Official MCP server for Ruixen UI.",
  "homepage": "https://ruixen.com",
  "bugs": {
    "url": "https://github.com/ruixenui/mcp.ruixen.com/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruixenui/mcp.ruixen.com.git"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts,json --exec \"npm run build\"",
    "pretest": "npm run build",
    "test": "node --test test/smoke.test.mjs",
    "prepublishOnly": "npm run build && npm test",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run"
  },
  "type": "module",
  "main": "./dist/server.js",
  "module": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "mcp": "./dist/server.js",
    "ruixen-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ruixen",
    "ruixen-ui",
    "shadcn",
    "tailwind",
    "ui",
    "components",
    "registry"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^22.14.1",
    "nodemon": "^3.1.0",
    "release-it": "^19.2.4",
    "shx": "^0.4.0",
    "typescript": "^5.8.3"
  },
  "author": "Ruixen UI",
  "license": "MIT"
}
